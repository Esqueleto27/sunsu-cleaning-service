---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import type { IconName } from './Icon.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  icon: IconName;
  title: string;
  description: string;
  image: ImageMetadata;
}

const { icon, title, description, image } = Astro.props;
---

<div
  class="group overflow-hidden rounded-card border border-navy/5 bg-white shadow-ambient transition-all duration-300 hover:-translate-y-2"
  data-reveal-item
>
  <div class="relative h-56 overflow-hidden lg:h-64">
    <Image
      src={image}
      alt={title}
      widths={[400, 640, 800]}
      sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
      quality={62}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
    <div class="absolute top-4 left-4 rounded-xl bg-white/90 p-2 text-turquoise shadow-sm backdrop-blur lg:top-5 lg:left-5 lg:p-2.5">
      <Icon name={icon} class="h-6 w-6 lg:h-7 lg:w-7" />
    </div>
  </div>
  <div class="p-8 lg:p-9">
    <h3 class="mb-3 font-display text-2xl font-bold text-navy lg:mb-4 lg:text-[26px]">{title}</h3>
    <p class="text-base leading-relaxed text-on-surface-variant lg:text-lg">{description}</p>
  </div>
</div>
