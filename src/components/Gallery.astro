---
import { Image } from 'astro:assets';
import { gallery } from '../data/gallery';
---

<section class="bg-surface py-32 lg:py-40" id="gallery">
  <div class="mx-auto max-w-container px-page">
    <div class="mb-16 text-center lg:mb-20" data-reveal>
      <h2 class="mb-4 font-display text-3xl font-semibold text-navy md:text-[40px] lg:mb-6 lg:text-[48px]">Resultados Impecables</h2>
      <p class="text-xl text-on-surface-variant lg:text-2xl">La claridad que nos define en cada proyecto finalizado.</p>
    </div>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8" data-reveal-group>
      {
        gallery.map((item) => (
          <div class="aspect-[3/4] overflow-hidden rounded-card transition-shadow duration-500 hover:shadow-2xl" data-reveal-item>
            <Image
              src={item.image}
              alt={item.alt}
              widths={[400, 640, 900]}
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
              quality={60}
              class="h-full w-full object-cover"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
