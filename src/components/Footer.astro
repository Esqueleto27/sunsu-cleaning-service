---
import Icon from './Icon.astro';
import { footerColumns, socialLinks } from '../data/site';
import { paymentMethods } from '../data/payment-methods';
---

<footer class="bg-navy-deep pt-20 pb-10 text-white/50 lg:pt-24 lg:pb-12">
  <div class="mx-auto mb-20 grid max-w-container grid-cols-1 gap-12 px-page md:grid-cols-4 lg:mb-24 lg:gap-16">
    <div class="flex flex-col gap-6">
      <div class="flex items-center gap-3">
        <img src="/logo-sunsu.webp" alt="Sunsu Cleaning Service" width="144" height="144" loading="lazy" class="h-10 w-10 lg:h-12 lg:w-12" />
        <span class="font-display text-2xl font-bold tracking-tighter text-white lg:text-[28px]">SUNSU</span>
      </div>
      <p class="text-base leading-relaxed lg:text-lg">
        Claridad luminosa en cada rincón. Servicios de limpieza profesional en la ciudad de Quito y valles cercanos.
      </p>
      <p class="text-sm text-white/40 lg:text-base">
        Aceptamos {paymentMethods.map((method) => method.label).join(' y ')}.
      </p>
    </div>

    {
      footerColumns.map((column) => (
        <div class="flex flex-col gap-4">
          <h3 class="mb-2 text-sm font-bold tracking-[0.2em] text-white uppercase lg:text-base">{column.title}</h3>
          {column.links.map((link) => (
            <a class="text-base transition-colors hover:text-turquoise lg:text-lg" href={link.href}>
              {link.label}
            </a>
          ))}
        </div>
      ))
    }

    <div class="flex flex-col gap-4">
      <h3 class="mb-2 text-sm font-bold tracking-[0.2em] text-white uppercase lg:text-base">Redes</h3>
      <div class="flex gap-4">
        {
          socialLinks.map((social) => (
            <a
              class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 transition-all hover:bg-turquoise hover:text-white lg:h-12 lg:w-12"
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
            >
              <Icon name={social.icon} class="h-5 w-5 lg:h-6 lg:w-6" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <div class="mx-auto max-w-container border-t border-white/5 px-page py-8 text-center text-xs tracking-wide lg:text-sm">
    © {new Date().getFullYear()} SUNSU Cleaning Service. Claridad luminosa en cada rincón.
  </div>
</footer>
