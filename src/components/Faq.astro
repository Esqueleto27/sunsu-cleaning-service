---
import Icon from './Icon.astro';
import { faqs } from '../data/faq';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="mx-auto max-w-container px-page py-32 lg:py-40" id="faq">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />

  <div class="mx-auto mb-16 max-w-3xl text-center lg:mb-20 lg:max-w-4xl" data-reveal>
    <h2 class="mb-4 font-display text-3xl font-semibold text-navy md:text-[40px] lg:mb-6 lg:text-[48px]">Preguntas Frecuentes</h2>
    <div class="mx-auto mb-6 h-1 w-20 bg-turquoise lg:mb-8 lg:w-24"></div>
    <p class="text-xl text-on-surface-variant lg:text-2xl">Resolvemos las dudas más comunes sobre nuestro servicio de limpieza en Quito.</p>
  </div>

  <div class="mx-auto max-w-3xl divide-y divide-navy/10 rounded-card border border-navy/5 bg-white shadow-testimonial lg:max-w-4xl" data-reveal-group>
    {
      faqs.map((faq) => (
        <details class="group p-6 md:p-8 lg:p-9" data-reveal-item>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-bold text-navy marker:content-none lg:text-xl">
            {faq.question}
            <Icon
              name="chevron-down"
              class="h-5 w-5 shrink-0 text-turquoise transition-transform duration-300 group-open:rotate-180 lg:h-6 lg:w-6"
            />
          </summary>
          <p class="mt-4 leading-relaxed text-on-surface-variant lg:text-lg">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</section>
